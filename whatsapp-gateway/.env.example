PORT=4000
# Token Bearer untuk endpoint outbound /messages. Harus sama dengan WHATSAPP_TOKEN di FinTrack.
GATEWAY_TOKEN=ganti-dengan-token-yang-juga-dipakai-laravel
# URL webhook FinTrack yang menerima pesan masuk dari WhatsApp.
FINTRACK_WEBHOOK_URL=http://localhost:8000/api/whatsapp/webhook
# Token header X-Webhook-Token. Harus sama dengan WHATSAPP_WEBHOOK_TOKEN di FinTrack.
FINTRACK_WEBHOOK_TOKEN=ganti-dengan-token-yang-sama-di-config-whatsapp-laravel
SESSION_PATH=./session